{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Docs",
      "detail": "Build the Great Docs site and mirror it into the committed docs/ folder.",
      "type": "process",
      "command": "${workspaceFolder}/venv/bin/python",
      "args": ["${workspaceFolder}/scripts/build_docs.py"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "clear": true }
    }
  ]
}
